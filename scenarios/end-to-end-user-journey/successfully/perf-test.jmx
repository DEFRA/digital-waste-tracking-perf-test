        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Assign traffic segment (10% direct API)" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">// Deterministic split by thread number: exactly 10% direct API
int threadNum = ctx.getThreadNum() // 0-based
boolean directApi = ((threadNum + 1) % 10 == 0)
vars.put(&apos;thread_num&apos;, String.valueOf(threadNum))
vars.put(&apos;traffic_is_direct&apos;, String.valueOf(directApi))
vars.put(&apos;traffic_segment&apos;, directApi ? &apos;direct_api&apos; : &apos;main_journey&apos;)

// Mark final iteration so cleanup runs once at thread end
def controller = ctx.getThreadGroup().getSamplerController()
int loops = (controller != null &amp;&amp; controller.respondsTo(&apos;getLoops&apos;)) ? controller.getLoops() : 1
int iteration = vars.getIteration()
boolean isLastIteration = loops &gt; 0 ? (iteration &gt;= loops) : false
vars.put(&apos;is_last_iteration&apos;, String.valueOf(isLastIteration))
</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
