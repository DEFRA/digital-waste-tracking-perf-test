    {&#xd;
      &quot;organisationName&quot;: &quot;Some Org&quot;,&#xd;
      &quot;relationshipRole&quot;: &quot;Employee&quot;,&#xd;
      &quot;roleName&quot;: &quot;Some role&quot;,&#xd;
      &quot;roleStatus&quot;: &quot;1&quot;&#xd;
    }&#xd;
  ]&#xd;
}</stringProp>
                      <stringProp name="Argument.metadata">=</stringProp>
                    </elementProp>
                  </collectionProp>
                </elementProp>
