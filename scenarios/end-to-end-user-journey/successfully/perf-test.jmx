            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Set journey by thread parity (50/50)" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">// Split users deterministically: even thread -&gt; upload, odd thread -&gt; api
int threadNum = ctx.getThreadNum()
int journeyIndex = (threadNum % 2 == 0) ? 1 : 0
vars.put(&apos;journey_index&apos;, String.valueOf(journeyIndex))
vars.put(&apos;journey&apos;, journeyIndex == 0 ? &apos;api&apos; : &apos;upload&apos;)
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223Sampler>
