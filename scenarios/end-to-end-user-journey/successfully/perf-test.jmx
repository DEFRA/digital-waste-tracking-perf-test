                      <boolProp name="HTTPArgument.always_encode">false</boolProp>
                      <stringProp name="Argument.value">{&#xd;
  &quot;userId&quot;: &quot;${__UUID()}&quot;,&#xd;
  &quot;email&quot;: &quot;ptest_${__time(yyyyMMddHHmmssSSS)}_${__Random(1000,9999)}@test.com&quot;,&#xd;
  &quot;firstName&quot;: &quot;John&quot;,&#xd;
  &quot;lastName&quot;: &quot;Doe&quot;,&#xd;
  &quot;loa&quot;: &quot;1&quot;,&#xd;
  &quot;aal&quot;: &quot;1&quot;,&#xd;
  &quot;enrolmentCount&quot;: 1,&#xd;
  &quot;enrolmentRequestCount&quot;: 1,&#xd;
