                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Set defra_user from Create User request body" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">def samplerData = prev.getSamplerData() ?: &apos;&apos;
def matcher = (samplerData =~ /&quot;email&quot;\s*:\s*&quot;([^&quot;]+)&quot;/)
if (matcher.find()) {
  vars.put(&apos;defra_user&apos;, matcher.group(1))
}</stringProp>
                </JSR223PostProcessor>
